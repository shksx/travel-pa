rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Users can read and write their own profile/prefs doc only.
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
